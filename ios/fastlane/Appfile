# App Identifier Configuration
app_identifier(ENV["APP_BUNDLE_ID"] || "com.yourcompany.BillKit")

# Apple ID for App Store Connect
apple_id(ENV["APPLE_ID"] || "your-apple-id@example.com")

# iTunes Connect Team ID
itc_team_id(ENV["ITC_TEAM_ID"])

# Developer Portal Team ID
team_id(ENV["TEAM_ID"])

